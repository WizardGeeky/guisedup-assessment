# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/guisedup_dev"

# JWT — change these before deploying
JWT_SECRET="your-jwt-secret-minimum-32-characters"
JWT_REFRESH_SECRET="your-refresh-secret-minimum-32-characters"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"
CORS_ORIGIN="*"

# Embeddings
EMBEDDING_DIMENSION=384

# Email / SMTP (Gmail)
# Leave blank to fall back to console-logging OTPs in development
SMTP_USER="SMTP_USER_EMAIL"
SMTP_PASS="SMTP_USER_PASSWORD"
